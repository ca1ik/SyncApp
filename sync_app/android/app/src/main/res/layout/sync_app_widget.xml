<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_main_area"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Kullanıcı adı -->
    <TextView
        android:id="@+id/widget_user_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sync"
        android:textSize="13sp"
        android:textColor="#FFFFFFFF"
        android:fontFamily="sans-serif-medium"
        android:ellipsize="end"
        android:maxLines="1" />

    <!-- Enerji seviyesi -->
    <TextView
        android:id="@+id/widget_energy_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Enerji: --"
        android:textSize="11sp"
        android:textColor="#CCE0E0E0" />

    <!-- Aktif sinyal -->
    <TextView
        android:id="@+id/widget_signal_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="2dp"
        android:text="--"
        android:textSize="22sp"
        android:gravity="center"
        android:textColor="#FFFFFFFF" />

    <!-- Hızlı sinyal düğmeleri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/widget_btn_1"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="🤗"
            android:textSize="16sp"
            android:padding="0dp" />

        <Button
            android:id="@+id/widget_btn_2"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="🤫"
            android:textSize="16sp"
            android:padding="0dp" />

        <Button
            android:id="@+id/widget_btn_3"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="😔"
            android:textSize="16sp"
            android:padding="0dp" />

    </LinearLayout>

</LinearLayout>
